<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Top Bar -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:src="@drawable/ic_play"
        android:rotation="90"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/colorOnSurface"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Close" />

    <TextView
        android:id="@+id/tvNowPlaying"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/now_playing_upper"
        android:letterSpacing="0.15"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurfaceVariant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnClose"
        app:layout_constraintBottom_toBottomOf="@id/btnClose" />

    <ImageButton
        android:id="@+id/btnShare"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_share"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/colorOnSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageButton
        android:id="@+id/btnMore"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:src="@drawable/ic_music_placeholder"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/colorOnSurface"
        android:visibility="invisible"
        app:layout_constraintEnd_toStartOf="@id/btnShare"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Split content container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/visualizerContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnClose"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/infoCard">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/stationArtwork"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.ExtraLarge"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="1:1" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Info Section on the right -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/infoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:strokeWidth="0dp"
        app:layout_constraintWidth_percent="0.45"
        app:layout_constraintBottom_toTopOf="@id/controlsLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnClose"
        app:layout_constraintVertical_chainStyle="packed">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:id="@+id/playerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/station_name_placeholder"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/playerDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/description_placeholder"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/playerNextSong"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Next: Unknown"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:alpha="0.7"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Controls on the right bottom -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/infoCard"
        app:layout_constraintStart_toStartOf="@id/infoCard"
        app:layout_constraintTop_toBottomOf="@id/infoCard">

        <!-- Sleep Timer Container -->
        <FrameLayout
            android:id="@+id/sleepTimerContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageButton
                 android:id="@+id/btnSleepTimer"
                 android:layout_width="48dp"
                 android:layout_height="48dp"
                 android:src="@drawable/ic_clock"
                 android:alpha="0.6"
                 android:background="?attr/selectableItemBackgroundBorderless"
                 app:tint="?attr/colorOnSurface"
                 android:clickable="false"
                 android:focusable="false"/>

            <TextView
                android:id="@+id/tvTimerCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="#80000000"
                android:padding="4dp"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:text="30"/>
        </FrameLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnPlayPauseContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_pause"
            app:backgroundTint="?attr/colorPrimary"
            app:tint="?attr/colorOnPrimary"
            app:fabCustomSize="64dp"
            app:maxImageSize="32dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.ExtraLarge"/>

        <ImageButton
             android:id="@+id/btnCarMode"
             android:layout_width="48dp"
             android:layout_height="48dp"
             android:src="@drawable/ic_car"
             android:alpha="0.6"
             android:background="?attr/selectableItemBackgroundBorderless"
             app:tint="?attr/colorOnSurface"
             android:layout_marginStart="16dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
