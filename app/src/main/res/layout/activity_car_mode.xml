<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/car_mode"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvBlessing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/blessing_trip"
        android:textColor="#FFD700"
        android:textSize="18sp"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:padding="8dp"
        android:background="#22FFFFFF"/>

    <Button
        android:id="@+id/btnQuickFavorite"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="@string/quick_favorite"
        android:textSize="20sp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#FF5722"/>

    <TextView
        android:id="@+id/tvTripTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="30 min"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:layout_marginBottom="16dp"
        android:drawablePadding="8dp"
        app:drawableStartCompat="@drawable/ic_clock"
        app:drawableTint="#FFFFFF"/>
        
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btnPrevious"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_skip_previous"
            android:contentDescription="@string/previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="24dp"
            app:tint="#FFFFFF"/>

        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_pause"
            android:contentDescription="@string/play_pause"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:tint="#FFFFFF"/>

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="@string/next"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="24dp"
            app:tint="#FFFFFF"/>
    </LinearLayout>
        
    <Button
        android:id="@+id/btnExitCarMode"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/cancel"
        android:textSize="18sp"/>

</LinearLayout>
