<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#6750A4"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/car_mode"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvBlessing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/blessing_trip"
        android:textColor="#FFD700"
        android:textSize="18sp"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:padding="8dp"
        android:background="#22FFFFFF"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnQuickFavorite"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="@string/quick_favorite"
        android:textSize="20sp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#FF5722"
        app:cornerRadius="24dp"
        app:strokeWidth="3dp"
        app:strokeColor="#FFFFFF"/>

    <TextView
        android:id="@+id/tvTripTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="30 min"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:layout_marginBottom="16dp"
        android:drawablePadding="8dp"
        app:drawableStartCompat="@drawable/ic_clock"
        app:drawableTint="#FFFFFF"/>
        
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayPause"
            android:layout_width="160dp"
            android:layout_height="160dp"
            app:icon="@drawable/ic_pause"
            app:iconSize="80dp"
            app:iconGravity="textStart"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            app:iconPadding="0dp"
            android:text=""
            android:contentDescription="@string/play_pause"
            app:cornerRadius="80dp"
            app:backgroundTint="#FFFFFF"
            app:iconTint="#6750A4"/>
    </LinearLayout>
        
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExitCarMode"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/cancel"
        android:textSize="18sp"
        app:cornerRadius="24dp"
        app:strokeWidth="3dp"
        app:strokeColor="#FFFFFF"/>

</LinearLayout>
